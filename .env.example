# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# -----------------------------------------------------------------------------
# Database selection
# Priority: DATABASE_URL -> DB_ENGINE=postgresql + DB_* -> SQLite fallback.
# Keep DATABASE_URL empty when using DB_* or SQLite.
# -----------------------------------------------------------------------------
DATABASE_URL=

# Local development fallback
DB_ENGINE=sqlite
SQLITE_PATH=db.sqlite3

# PostgreSQL option A: uncomment and set DATABASE_URL.
# DATABASE_URL=postgresql://ibsec_user:strong-password@localhost:5432/ibsec_lms

# PostgreSQL option B: set DB_ENGINE=postgresql and configure DB_*.
# DB_ENGINE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ibsec_lms
# DB_USER=ibsec_user
# DB_PASSWORD=strong-password

# PostgreSQL connection settings
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True
# DB_SSLMODE=require

# Metadata used in generated DOCX certificates
DOCUMENT_ORGANIZATION_NAME=IBSec LMS
DOCUMENT_SIGNER_TITLE=Ответственный за информационную безопасность
DOCUMENT_SIGNER_NAME=
