# Copy to demo/.env and replace every placeholder before starting the demo stack.
SECRET_KEY=replace-with-a-long-random-demo-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

POSTGRES_DB=ibsec_lms_demo
POSTGRES_USER=ibsec_demo_user
POSTGRES_PASSWORD=replace-with-a-strong-demo-database-password
POSTGRES_HOST_PORT=55432
DB_CONN_MAX_AGE=60

RUN_MIGRATIONS=True
COLLECT_STATIC=True

GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_LOG_LEVEL=info

DOCUMENT_ORGANIZATION_NAME=IBSec LMS Demo
DOCUMENT_SIGNER_TITLE=Ответственный за информационную безопасность
DOCUMENT_SIGNER_NAME=

DEMO_ADMIN_PASSWORD=replace-admin-password
DEMO_SECURITY_OFFICER_PASSWORD=replace-security-officer-password
DEMO_EMPLOYEE_PASSWORD=replace-employee-password
DEMO_EMPLOYEE2_PASSWORD=replace-employee2-password
