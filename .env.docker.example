# Copy to .env.docker and replace every placeholder before deployment.

# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=lms.example.com
CSRF_TRUSTED_ORIGINS=https://lms.example.com

# PostgreSQL 18 container
POSTGRES_DB=ibsec_lms
POSTGRES_USER=ibsec_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST_PORT=55432
DB_CONN_MAX_AGE=60

# Container initialization
RUN_MIGRATIONS=True
COLLECT_STATIC=True

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_LOG_LEVEL=info

# Generated DOCX certificates
DOCUMENT_ORGANIZATION_NAME=IBSec LMS
DOCUMENT_SIGNER_TITLE=Ответственный за информационную безопасность
DOCUMENT_SIGNER_NAME=
