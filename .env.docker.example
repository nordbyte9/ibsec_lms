# Copy this file to .env.docker and change all placeholder secrets.
# The supplied archive also contains a ready demo .env.docker for local testing.

# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# PostgreSQL 18 container
POSTGRES_DB=ibsec_lms
POSTGRES_USER=ibsec_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password
# Host port 55432 avoids conflict with a locally installed PostgreSQL on 5432.
POSTGRES_HOST_PORT=55432
DB_CONN_MAX_AGE=60

# Initialization
RUN_MIGRATIONS=True
COLLECT_STATIC=True
# Set True only for a demonstration environment.
LOAD_DEMO_DATA=False

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_LOG_LEVEL=info
